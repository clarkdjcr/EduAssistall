rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helper functions
    // -------------------------------------------------------------------------

    // Reads the caller's user document (cached within a request — counts as 1 get).
    function callerData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin()   { return callerData().role == "admin"; }
    function isEducator(){ return callerData().role in ["teacher", "admin"]; }

    // True if the caller has a confirmed studentAdultLink to studentId.
    // Requires document IDs in the form {adultId}_{studentId} (enforced in StudentAdultLink.init).
    // Both exists() and get() hit the same path — Firestore caches the read.
    function isLinked(studentId) {
      let p = /databases/$(database)/documents/studentAdultLinks/$(request.auth.uid + '_' + studentId);
      return exists(p) && get(p).data.confirmed == true;
    }

    function isLinkedTeacher(studentId) {
      let p = /databases/$(database)/documents/studentAdultLinks/$(request.auth.uid + '_' + studentId);
      return exists(p)
          && get(p).data.confirmed == true
          && get(p).data.adultRole == "teacher";
    }

    function isLinkedParent(studentId) {
      let p = /databases/$(database)/documents/studentAdultLinks/$(request.auth.uid + '_' + studentId);
      return exists(p)
          && get(p).data.confirmed == true
          && get(p).data.adultRole == "parent";
    }

    // -------------------------------------------------------------------------
    // users/{uid}
    // Owner read/write allowed except for role changes. Linked adults can read
    // for dashboard display.
    // Admins can read all profiles.
    // Role changes require admin — enforced by checking that a non-admin cannot
    // change the role field.
    // -------------------------------------------------------------------------
    match /users/{uid} {
      // Users can always read their own profile (including before it exists).
      allow read: if request.auth != null && request.auth.uid == uid;
      // Self-writes allowed unless changing the role field. Roles are assigned
      // by registration, teacher invite/import, SSO provisioning, or admin setup.
      allow write: if request.auth != null && request.auth.uid == uid
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(["role"])
              || isAdmin());
      // Linked adults and admins can read for dashboard display.
      allow read: if request.auth != null && (isLinked(uid) || isAdmin());
      // First-time self-profile creation is parent-only. Student accounts are
      // created through teacher invite/import flows, and teacher/admin roles are
      // provisioned outside open client registration.
      allow create: if request.auth != null
          && request.auth.uid == uid
          && request.resource.data.role == "parent";
    }

    // -------------------------------------------------------------------------
    // learningProfiles/{studentId}
    // -------------------------------------------------------------------------
    match /learningProfiles/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      allow read, write: if request.auth != null && isLinkedTeacher(studentId);
      allow read:        if request.auth != null && isLinkedParent(studentId);
      allow read, write: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // studentAdultLinks/{linkId}  (linkId == "{adultId}_{studentId}")
    //
    // Adult/student relationship contract:
    //   CREATE  — adult initiates a teacher or parent link. Current app flows
    //             create confirmed links after teacher invite or parent lookup.
    //   UPDATE  — retained for legacy pending links only: the named student may
    //             confirm an unexpired pending link by changing `confirmed` only.
    //   DELETE  — either party withdraws/removes the link.
    // -------------------------------------------------------------------------
    match /studentAdultLinks/{linkId} {
      allow read: if request.auth != null && (
          request.auth.uid == resource.data.adultId ||
          request.auth.uid == resource.data.studentId ||
          isLinkedTeacher(resource.data.studentId) ||
          isAdmin()
      );

      // Adult creates the link. Current parent and teacher flows create
      // confirmed links after server-side lookup/invite checks.
      // Transfer case: a currently-linked teacher may also create a new confirmed
      // teacher link for one of their students (individual or bulk transfer).
      // Constraints: caller must be a confirmed linked teacher for that student,
      // and the new link must be a confirmed teacher link (no forging parent links).
      allow create: if request.auth != null && (
          request.auth.uid == request.resource.data.adultId
          || (
              isLinkedTeacher(request.resource.data.studentId)
              && request.resource.data.adultRole == "teacher"
              && request.resource.data.confirmed == true
          )
      );

      // Legacy pending-link confirmation. Constraints:
      //   • caller must be the named student
      //   • only the `confirmed` field changes (no other data mutated)
      //   • confirmed must be set to true (not false — decline uses delete)
      //   • link must not have expired
      allow update: if request.auth != null
          && request.auth.uid == resource.data.studentId
          && request.resource.data.confirmed == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["confirmed"])
          && request.time < resource.data.expiresAt;

      // End-of-year class archival: the owning adult (or a school admin) marks
      // links archived. Only the three archival fields may change; archived must
      // be set to true (no un-archiving from the client).
      allow update: if request.auth != null
          && (request.auth.uid == resource.data.adultId || isAdmin())
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["archived", "schoolYear", "archivedAt"])
          && request.resource.data.archived == true;

      // Either party or a school admin may remove the relationship.
      allow delete: if request.auth != null && (
          request.auth.uid == resource.data.adultId ||
          request.auth.uid == resource.data.studentId ||
          isAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // learningPaths/{pathId}
    // -------------------------------------------------------------------------
    match /learningPaths/{pathId} {
      allow read: if request.auth != null && (
          resource.data.studentId == request.auth.uid ||
          isLinked(resource.data.studentId) ||
          isAdmin()
      );
      allow create, update: if request.auth != null && (
          isLinkedTeacher(request.resource.data.studentId) ||
          isAdmin() ||
          (
            resource.data.studentId == request.auth.uid &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.archivedBy == request.auth.uid &&
            request.resource.data.isActive == false &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(["isActive", "workflowStatus", "archivedAt", "archivedBy"])
          )
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // contentItems/{itemId}  — shared catalog, contains no personal data
    // -------------------------------------------------------------------------
    match /contentItems/{itemId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // studentProgress/{docId}  (docId == "{studentId}_{contentItemId}")
    // -------------------------------------------------------------------------
    match /studentProgress/{docId} {
      allow read: if request.auth != null && (
          resource.data.studentId == request.auth.uid ||
          isLinked(resource.data.studentId) ||
          isAdmin()
      );
      allow create: if request.auth != null && (
          request.resource.data.studentId == request.auth.uid || isAdmin()
      );
      allow update: if request.auth != null && (
          resource.data.studentId == request.auth.uid ||
          isLinkedTeacher(resource.data.studentId) ||
          isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // testAttempts/{attemptId}
    // Students create/read their own practice-test results. Linked adults and
    // admins can read for progress dashboards and Teacher Assist analytics.
    // -------------------------------------------------------------------------
    match /testAttempts/{attemptId} {
      allow read: if request.auth != null && (
          resource.data.studentId == request.auth.uid ||
          isLinked(resource.data.studentId) ||
          isAdmin()
      );
      allow create: if request.auth != null && (
          request.resource.data.studentId == request.auth.uid || isAdmin()
      );
      allow update: if false;
      allow delete: if request.auth != null && (
          resource.data.studentId == request.auth.uid || isAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // conversations/{studentId}/messages/{msgId}
    // Students write their own messages. Cloud Functions write AI replies via
    // Admin SDK (bypasses these rules). No client can update or delete.
    // -------------------------------------------------------------------------
    match /conversations/{studentId}/messages/{msgId} {
      allow read: if request.auth != null && (
          request.auth.uid == studentId ||
          isLinked(studentId) ||
          isAdmin()
      );
      allow create: if request.auth != null && request.auth.uid == studentId;
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // recommendations/{recId}
    // Cloud Functions create; linked teachers can approve/reject. Intermediate
    // AI recommendations stay adult/admin-facing until assigned as learning paths.
    // -------------------------------------------------------------------------
    match /recommendations/{recId} {
      allow read: if request.auth != null && (
          resource.data.teacherId == request.auth.uid ||
          isLinked(resource.data.studentId) ||
          isAdmin()
      );
      allow update: if request.auth != null && (
          isLinkedTeacher(resource.data.studentId) || isAdmin()
      );
      allow create, delete: if false;
    }

    // -------------------------------------------------------------------------
    // messageThreads/{threadId}  +  messages subcollection
    // Access is restricted to thread participants (stored in participantIds array).
    // -------------------------------------------------------------------------
    match /messageThreads/{threadId} {
      allow read: if request.auth != null
          && request.auth.uid in resource.data.participantIds;
      allow create: if request.auth != null
          && request.auth.uid in request.resource.data.participantIds;
      allow update: if request.auth != null
          && request.auth.uid in resource.data.participantIds;
      allow delete: if false;
    }
    match /messageThreads/{threadId}/messages/{msgId} {
      allow read: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds;
      allow create: if request.auth != null
          && request.auth.uid in
             get(/databases/$(database)/documents/messageThreads/$(threadId)).data.participantIds
          && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // learningMilestones/{studentId}/milestones/{milestoneId}
    // Written only by Cloud Functions (Admin SDK).
    // -------------------------------------------------------------------------
    match /learningMilestones/{studentId}/milestones/{milestoneId} {
      allow read: if request.auth != null && (
          request.auth.uid == studentId ||
          isLinked(studentId) ||
          isAdmin()
      );
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // learningJournal/{studentId}/entries/{entryId}
    // Written only by Cloud Functions (Admin SDK).
    // -------------------------------------------------------------------------
    match /learningJournal/{studentId}/entries/{entryId} {
      allow read: if request.auth != null && (
          request.auth.uid == studentId ||
          (isLinkedTeacher(studentId) && resource.data.shareWithTeacher == true) ||
          (isLinkedParent(studentId) && resource.data.shareWithParent == true) ||
          isAdmin()
      );
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // companionLocks/{studentId}
    // Students read their own lock status. Only educators can lock/unlock.
    // -------------------------------------------------------------------------
    match /companionLocks/{studentId} {
      allow read: if request.auth != null && request.auth.uid == studentId;
      allow write: if request.auth != null && isEducator();
    }

    // -------------------------------------------------------------------------
    // activeSessions/{studentId}  (FR-200 live session tracking)
    // Students write their own session. Linked teachers and admins can read
    // (for the live monitor tab).
    // -------------------------------------------------------------------------
    match /activeSessions/{studentId} {
      allow read, write: if request.auth != null && request.auth.uid == studentId;
      allow read: if request.auth != null && (isLinkedTeacher(studentId) || isAdmin());
    }

    // -------------------------------------------------------------------------
    // sessionFlags/{studentId}/flags/{flagId}
    // Educator-only view — students must NOT see their own flags (it would reveal
    // frustration/safety classification details that could be gamed).
    // Written only by Cloud Functions.
    // -------------------------------------------------------------------------
    match /sessionFlags/{studentId}/flags/{flagId} {
      allow read: if request.auth != null && (
          isLinkedTeacher(studentId) ||
          isLinkedParent(studentId) ||
          isAdmin()
      );
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // districtConfig/{districtId}
    // -------------------------------------------------------------------------
    match /districtConfig/{districtId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // districtSecrets/{districtId}
    // Stores per-district Anthropic API keys. Never readable or writable by
    // clients — only the Admin SDK (Cloud Functions) can access this collection.
    // -------------------------------------------------------------------------
    match /districtSecrets/{districtId} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // classroomConfig/{teacherId}
    // -------------------------------------------------------------------------
    match /classroomConfig/{teacherId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
      allow read, write: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // teacherWiki/{teacherId}/entries/{entryId}
    // Personal teaching-knowledge entries that amplify the owning teacher's lesson-plan
    // generation. Owner-locked. Admins may read (teacher-authored professional content).
    // The lesson-plan Cloud Function reads via Admin SDK (bypasses these rules).
    // -------------------------------------------------------------------------
    match /teacherWiki/{teacherId}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
      allow read:        if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // teacherJournal/{teacherId}/entries/{entryId}  (Phase 2)
    // Private teacher reflection. STRICTLY owner-only — not readable by admins,
    // linked adults, or anyone else. Never read by Cloud Functions; excluded from
    // audit logs and data exports.
    // -------------------------------------------------------------------------
    match /teacherJournal/{teacherId}/entries/{entryId} {
      allow read, write: if request.auth != null && request.auth.uid == teacherId;
    }

    // -------------------------------------------------------------------------
    // teacherHints/{studentId}  — one doc per student, written by linked teacher
    // -------------------------------------------------------------------------
    match /teacherHints/{studentId} {
      allow read: if request.auth != null && (
          request.auth.uid == studentId ||
          isLinkedTeacher(studentId) ||
          isAdmin()
      );
      allow write: if request.auth != null && (
          isLinkedTeacher(studentId) || isAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // systemConfig/{docId}  — all authenticated users can read (DataResidencyService
    // reads systemConfig/dataResidency on every sign-in to verify US data residency).
    // Only admins may write.
    // -------------------------------------------------------------------------
    match /systemConfig/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // Educator / ops monitoring — readable by teachers+admins, written by Functions
    // -------------------------------------------------------------------------
    match /latencyStats/{docId}     { allow read: if request.auth != null && isEducator(); allow write: if false; }
    match /safetyBenchmarks/{docId} { allow read: if request.auth != null && isEducator(); allow write: if false; }
    match /piiScanLogs/{docId}      { allow read: if request.auth != null && isEducator(); allow write: if false; }
    match /piiScanResults/{docId}   { allow read: if request.auth != null && isAdmin();    allow write: if false; }
    match /drBackupLog/{docId}      { allow read: if request.auth != null && isAdmin();    allow write: if false; }

    // -------------------------------------------------------------------------
    // Collections written exclusively by Cloud Functions via Admin SDK.
    // Admin SDK bypasses these rules, so `write: if false` purely prevents
    // any client from writing directly.
    // -------------------------------------------------------------------------
    match /criticalSafetyEvents/{eventId} { allow read, write: if false; }
    match /safetyClassifications/{docId}  { allow read, write: if false; }
    // auditLogs: clients may append their own events (sign-in, sign-out, export, etc.).
    // No client may read, update, or delete — tamper-evident append-only trail.
    match /auditLogs/{docId}              { allow create: if request.auth != null; allow read, update, delete: if false; }
    match /rateLimits/{docId}             { allow read, write: if false; }
    match /performanceMetrics/{docId}     { allow read, write: if false; }
    match /healthPing/{docId}             { allow read, write: if false; }

    // -------------------------------------------------------------------------
    // aiAuditLog/{eventId}  (FR-G6)
    // Append-only compliance record for every AI generation event.
    // Admins may read for compliance reviews and e-discovery.
    // No client — including admins — may update or delete. Only Cloud Functions
    // write via Admin SDK, which bypasses these rules; the `write: if false`
    // prevents any direct client write. Update and delete are permanently closed.
    // -------------------------------------------------------------------------
    match /aiAuditLog/{eventId} {
      allow read:          if request.auth != null && isAdmin();
      allow create:        if false;
      allow update, delete: if false;
    }

    // -------------------------------------------------------------------------
    // Firebase document backend collections
    // -------------------------------------------------------------------------

    // groundingContent / curriculumContent — read by all authenticated users;
    // written only by admins (seeding scripts use Admin SDK, but allow admin client too).
    match /groundingContent/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /curriculumContent/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // districtPolicies — read by all authenticated users; written by admins.
    match /districtPolicies/{docId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }

    // officialDocuments — teachers read their own; admins read all.
    // Teachers may update approvalStatus only (via approveDocument Cloud Function).
    // Create and delete are restricted to Cloud Functions (Admin SDK).
    match /officialDocuments/{docId} {
      allow read: if request.auth != null && (
          resource.data.teacherUid == request.auth.uid || isAdmin()
      );
      allow update: if request.auth != null
          && isEducator()
          && resource.data.teacherUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["approvalStatus", "reviewedBy", "reviewedAt"]);
      allow create, delete: if false;
    }

    // publicStandardsSources / standardsUpdateAlerts / standardsMonitorRuns
    // are written only by scheduled/callable Cloud Functions through Admin SDK.
    // Admins can read them to review public standards updates before accepting
    // curriculum changes into the approved source set.
    match /publicStandardsSources/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }
    match /standardsUpdateAlerts/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }
    match /standardsMonitorRuns/{docId} {
      allow read: if request.auth != null && isAdmin();
      allow write: if false;
    }

    // -------------------------------------------------------------------------
    // weeklyAssignments/{assignmentId}
    // Teachers create/update. Linked adults/admins can read. Students receive
    // assigned work through learningPaths/contentItems instead.
    // -------------------------------------------------------------------------
    match /weeklyAssignments/{assignmentId} {
      allow read: if request.auth != null && (
          isLinked(resource.data.studentId) ||
          isAdmin()
      );
      allow create: if request.auth != null && (
          isLinkedTeacher(request.resource.data.studentId) || isAdmin()
      );
      allow update: if request.auth != null && (
          isLinkedTeacher(resource.data.studentId) ||
          isAdmin()
      );
      allow delete: if request.auth != null && isAdmin();
    }

    // -------------------------------------------------------------------------
    // gradeWeights/{teacherId}
    // -------------------------------------------------------------------------
    match /gradeWeights/{teacherId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == teacherId || isAdmin());
    }

    // -------------------------------------------------------------------------
    // gradingCriteria/{criteriaId}
    // -------------------------------------------------------------------------
    match /gradingCriteria/{criteriaId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
          request.resource.data.teacherId == request.auth.uid || isAdmin()
      );
      allow delete: if request.auth != null && (
          resource.data.teacherId == request.auth.uid || isAdmin()
      );
    }

    // -------------------------------------------------------------------------
    // sharedFiles/{fileId}
    // Individual files: owner and their linked adults.
    // Group files: any group member.
    // -------------------------------------------------------------------------
    match /sharedFiles/{fileId} {
      allow read: if request.auth != null && (
          resource.data.uploadedBy == request.auth.uid ||
          (resource.data.scope == "individual" && isLinked(resource.data.ownerId)) ||
          (resource.data.scope == "group" && request.auth.uid in resource.data.groupMemberIds) ||
          isAdmin()
      );
      allow create: if request.auth != null && (
          request.resource.data.uploadedBy == request.auth.uid
      );
      allow delete: if request.auth != null && (
          resource.data.uploadedBy == request.auth.uid || isAdmin()
      );
      allow update: if false;
    }

    // NOTE: no catch-all. Firestore denies by default — any collection not
    // listed above is implicitly inaccessible to all clients.

  }
}
