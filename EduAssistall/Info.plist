<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- FR-400: Enforce TLS — no cleartext HTTP allowed anywhere in the app. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- Export compliance: app uses only standard HTTPS/TLS — exempt from non-exempt encryption reporting. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Required for Firebase Cloud Messaging to deliver notifications when the app is in the background. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>
</dict>
</plist>
