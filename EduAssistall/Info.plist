<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>LSApplicationCategoryType</key>
    <string>public.app-category.education</string>
    <!-- FR-400: Enforce TLS — no cleartext HTTP allowed anywhere in the app. -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <false/>
    </dict>

    <!-- Export compliance: app uses only standard HTTPS/TLS — exempt from non-exempt encryption reporting. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Required for Firebase Cloud Messaging to deliver notifications when the app is in the background. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- Required when the app calls requestAuthorization() for push notifications. -->
    <key>NSUserNotificationsUsageDescription</key>
    <string>EduAssist sends you notifications when your teacher assigns new content or sends you a message.</string>

    <!-- Disable Firebase Messaging app delegate proxy. We set up Messaging.delegate manually in AppDelegate
         (iOS only). Setting this to NO prevents FCM from swizzling on macOS where UIApplicationDelegate
         does not exist, eliminating the I-FCM001000 / I-SWZ001014 log noise. -->
    <key>FirebaseAppDelegateProxyEnabled</key>
    <false/>

    <!-- Required by Firebase OAuthProvider (Microsoft/Entra sign-in) to redirect back to the app after browser auth. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>app-1-863094558300-ios-334dfc479ad6ba33522099</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
